
{
  "layer": "top",
  "position": "top",
  "height": 30,
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["clock"],
  "modules-right": ["custom/filemanager","custom/bluetooth","cpu", "memory", "pulseaudio", "network", "battery"],

  "sway/workspaces": {
    "disable-scroll": false,
    "format": "{name}",
    "format-focused": "[{name}]",
    "format-visible": "{name}",
    "format-urgent": " {name}",
    "on-click": "swaymsg workspace {name}"
  },

  "sway/mode": {
    "format": " {mode}"
  },

  "clock": {
    "interval": 60,
    "format": "  {:%a %d %b | %H:%M}"
  },

  "cpu": {
    "format": " {usage}%",
    "tooltip": false
  },

  "memory": {
    "format": " {used:0.1f}G",
    "tooltip": false
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": " muted",
    "scroll-step": 5
  },
"custom/filemanager": {
  "format": " files", // this is a folder icon
  "tooltip": "Open File Manager",
  "on-click": "thunar",
  "interval": 3600
},

  "custom/bluetooth": {
  "format": " Bluetooth",  // You can use an icon here (I've used a Bluetooth icon, but feel free to customize it)
  "tooltip": "Open Bluetooth Manager", // This is the tooltip that appears when you hover over the icon
  "on-click": "blueman-manager", // This will open the Bluetooth manager when clicked
  "interval": 3600 // This controls how often it updates (in seconds)
}





,
 
"network": {
  "interface": "wlp2s0",
  "format-wifi": " {essid}",
  "format-disconnected": "⚠ No Network",
  "tooltip": true
}
,

  "battery": {
    "format": "  {capacity}%",
    "format-charging": " {capacity}%"
  }
}

