{
  "layer": "top",
  "position": "top",
  "height": 30,
  "modules-left": ["sway/workspaces","sway/window"],
  "modules-center": ["clock"],
  "modules-right": ["custom/filemanager", "custom/bluetooth","custom/net_speed", "cpu", "memory", "pulseaudio", "network", "battery"],

  "sway/workspaces": {
    "disable-scroll": false,
    "format": "{name}",
    "format-focused": "[{name}]",
    "format-visible": "{name}",
    "format-urgent": " {name}",
    "on-click": "swaymsg workspace {name}"
  },

  "clock": {
    "interval": 60,
    "format": "  {:%a %d %b | %H:%M}"
  },

  "cpu": {
    "format": " {usage}%",
    "tooltip": false,
    "on-click": "alacritty -e btop"
  },

  "memory": {
    "format": " {used:0.1f}G",
    "tooltip": false,
    "on-click": "gnome-system-monitor"
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": " muted",
    "on-click": "pavucontrol",
    "scroll-step": 5
  },

  "custom/filemanager": {
    "format": " files",
    "tooltip": "Open File Manager",
    "on-click": "thunar",
    "interval": 3600
  },

  "custom/bluetooth": {
    "format": "󰂯 Bluetooth",
    "tooltip": "Open Bluetooth Manager",
    "on-click": "blueman-manager",
    "interval": 3600
  },

  "network": {
    "interface": "wlp2s0",
    "format-wifi": " {essid}",
    "format-disconnected": "⚠ No Network",
    "tooltip": true,
    "on-click": "nm-connection-editor"
  },

  "battery": {
    "format": "  {capacity}%",
    "format-charging": " {capacity}%"
  },

   "sway/window": {
    "format": "{title}",
    "max-length": 50,
    "tooltip": true
  },
  "custom/net_speed": {
  "format": "{}",
  "exec": "~/.config/waybar/net_speed.sh",
  "interval": 1,
  "return-type": "text",
  "tooltip": "true"
}


}

