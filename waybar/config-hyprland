  "clock": {
    "interval": 60,
    "format": " {:%a %d %b | %I:%M %p}"
  },

  "cpu": {
    "format": "´ïø {usage}%",
    "tooltip": false,
    "on-click": "alacritty -e btop"
  },

  "memory": {
    "format": "´ö© {used:0.1f}G",
    "tooltip": false,
    "on-click": "gnome-system-monitor"
  },

  "pulseaudio": {
    "format": "´Ç¿ {volume}%",
    "format-muted": "´Ü® muted",
    "on-click": "pavucontrol",
    "scroll-step": 5
  },

  "custom/filemanager": {
    "format": "´ü╝ files",
    "tooltip": "Open File Manager",
    "on-click": "thunar",
