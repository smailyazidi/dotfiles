
{
  "layer": "top",
  "position": "top",
  "height": 30,

"modules-left": [
  "hyprland/workspaces",
  "custom/app_firefox",
  "custom/app_discord",
  "custom/app_whatsapp",
  "custom/app_spotify",
  "custom/app_terminal",
  "custom/app_nvim",
  "custom/app_vscode",
  "hyprland/window"
],
  "modules-center": ["clock"],
  "modules-right": ["custom/filemanager", "custom/bluetooth", "custom/net_speed", "cpu",  "custom/keyboard-state" , "memory", "pulseaudio", "network", "battery","custom/lock"],


  "hyprland/workspaces": {
    "disable-scroll": false,
    "format": "{name}",
    "format-focused": "[{name}]",
    "format-visible": "{name}",
    "format-urgent": "´ü¬ {name}",
    "on-click": "hyprctl dispatch workspace {name}"
